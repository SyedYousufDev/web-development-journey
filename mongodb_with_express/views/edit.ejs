<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Message</title>
</head>
<body>
    <h5>Edit Your Message having ID: <%= chat.id %></h5>
     <p>This chat was sent from <b><%= chat.from %></b> to <b> <%= chat.to %></b></p>

<form method="POST" action="/chats/<%= chat._id %>?_method=PUT">
 <textarea name="message" rows="5" cols="10"><%= chat.message %></textarea>
    <button>Edit</button>
</form>
</body>
</html>